# ─── App ────────────────────────────────────────────────────────────────────────
APP_NAME=MyApp
APP_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000

# ─── Security ────────────────────────────────────────────────────────────────────
# Must be a strong random string
SECRET_KEY=change-me-to-a-strong-random-secret
# Must be exactly 32 characters for AES-256
TOTP_ENCRYPTION_KEY=change-me-32-chars-exactly-here!

# ─── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@db:5432/appdb?sslmode=disable

# ─── JWT ────────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_CHALLENGE_TOKEN_EXPIRE_MINUTES=5

# ─── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Email ───────────────────────────────────────────────────────────────────────
# smtp | sendgrid | resend
MAIL_PROVIDER=smtp
MAIL_FROM=noreply@myapp.com
MAIL_FROM_NAME=MyApp
# Used when MAIL_PROVIDER=smtp
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Used when MAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=
# Used when MAIL_PROVIDER=resend
RESEND_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────────
# local | s3
STORAGE_BACKEND=local
STORAGE_PATH=./uploads
# Used when STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=myapp
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=

# ─── Frontend ────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:8080/api/v1
NUXT_PUBLIC_WS_BASE=ws://localhost:8080
