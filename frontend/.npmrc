shamefully-hoist=true
# pnpm does not auto-install optional platform binaries on first install.
# Run `pnpm install` a second time if you get "Cannot find native binding" errors.
# Or install the platform-specific packages explicitly:
#   pnpm add @oxc-parser/binding-darwin-arm64@0.117.0 \
#            @oxc-transform/binding-darwin-arm64@0.117.0 \
#            @oxc-minify/binding-darwin-arm64@0.117.0
